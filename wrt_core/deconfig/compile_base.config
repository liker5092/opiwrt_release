# Compile
CONFIG_USE_APK=n
CONFIG_DEVEL=y
CONFIG_CCACHE=y

# BUSYBOX
CONFIG_BUSYBOX_CUSTOM=y
CONFIG_BUSYBOX_CONFIG_TELNET=y

# Proto
CONFIG_PACKAGE_proto-bonding=y
CONFIG_PACKAGE_luci-proto-wireguard=y
CONFIG_PACKAGE_luci-proto-relay=y


# Libraries
CONFIG_PACKAGE_luci-lib-ipkg=y
CONFIG_PACKAGE_libopenssl-legacy=y

# Disable Package
CONFIG_PACKAGE_automount=y

#  DEFAULT SET
CONFIG_PACKAGE_default-settings=y
CONFIG_PACKAGE_default-settings-chn=y

#  Coremark
CONFIG_PACKAGE_coremark=y
CONFIG_COREMARK_OPTIMIZE_O3=y
CONFIG_COREMARK_ENABLE_MULTITHREADING=y
CONFIG_COREMARK_NUMBER_OF_THREADS=6

#  iptables nft
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_ip6tables-nft=y

# 2026.6.4 add turboacc depends and vrf
CONFIG_PACKAGE_kmod-tcp-bbr=y
# 2026.6.7 added vrf depends
CONFIG_NET_L3_MASTER_DEV=y
CONFIG_NET_VRF=y
CONFIG_PACKAGE_kmod-vrf=y

# 2026.6.8 enable xfs file
# XFS 文件系统
CONFIG_PACKAGE_kmod-fs-xfs=y
#CONFIG_KERNEL_XFS_FS=y
#CONFIG_KERNEL_XFS_QUOTA=y
#CONFIG_KERNEL_XFS_POSIX_ACL=y

# XFS 用户工具
#CONFIG_PACKAGE_xfs-mkfs=y
#CONFIG_PACKAGE_xfs-admin=y
#CONFIG_PACKAGE_xfs-fsck=y
#CONFIG_PACKAGE_xfs-growfs=y
#CONFIG_PACKAGE_xfs-fsr=y
#CONFIG_PACKAGE_xfs-copy=y
#CONFIG_PACKAGE_xfs-info=y
#CONFIG_PACKAGE_xfs-libuuid=y
#CONFIG_PACKAGE_xfs-mdrestore=y
#CONFIG_PACKAGE_xfs-metadump=y
#CONFIG_PACKAGE_xfs-quota=y
#CONFIG_PACKAGE_xfs-rtcp=y

# Package about VPN 2026.6.8
CONFIG_PACKAGE_easytier=y
# ========== WireGuard ==========
CONFIG_PACKAGE_kmod-wireguard=y
CONFIG_PACKAGE_luci-app-wireguard=y
CONFIG_PACKAGE_wireguard-tools=y
# ========== OpenVPN ==========
CONFIG_PACKAGE_luci-app-openvpn=y
CONFIG_PACKAGE_openvpn-easy-rsa=y
CONFIG_PACKAGE_openvpn-openssl=y
# ========== IPsec/IKEv2 ==========
CONFIG_PACKAGE_strongswan=y
CONFIG_PACKAGE_strongswan-mod-kernel-libipsec=y
# ========== ZeroTier ==========
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_zerotier=y
# ========== Tailscale ==========
CONFIG_PACKAGE_tailscale=y
# ========== SoftEther ==========
CONFIG_PACKAGE_luci-app-softether=y
CONFIG_PACKAGE_softethervpn=y

# Enable Luci App
CONFIG_PACKAGE_luci-app-easytier=n
CONFIG_EASYTIER_INCLUDE_WEBCONSOLE=n
CONFIG_PACKAGE_luci-app-istorex=y
CONFIG_PACKAGE_luci-app-lucky=n
CONFIG_PACKAGE_luci-app-mosdns=n
CONFIG_PACKAGE_luci-app-oaf=y
CONFIG_PACKAGE_luci-app-pbr=n
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-wol=n

# enable openvpn
CONFIG_PACKAGE_luci-proto-openvpn=y

CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-theme-aurora=n
CONFIG_PACKAGE_luci-app-aurora-config=n
